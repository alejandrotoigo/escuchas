    {
      "name": "Spots",
      "item": [
        {
          "name": "POST Subir Spot",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "  const data = pm.response.json();",
                  "  if (data.ad_id) {",
                  "    pm.collectionVariables.set(\"adId\", String(data.ad_id));",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "description": "Sube un spot. Si Postman no toma la variable mediaFilePath como archivo, elegi el archivo manualmente en el campo file.",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "{{mediaFilePath}}"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/ads/upload?campaign_id={{campaignId}}&title={{adTitle}}",
              "host": ["{{baseUrl}}"],
              "path": ["ads", "upload"],
              "query": [
                {
                  "key": "campaign_id",
                  "value": "{{campaignId}}"
                },
                {
                  "key": "title",
                  "value": "{{adTitle}}"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "GET Listar Spots",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/ads",
              "host": ["{{baseUrl}}"],
              "path": ["ads"]
            }
          },
          "response": []
        }
      ]
    },
