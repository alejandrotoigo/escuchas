    {
      "name": "Campanas",
      "item": [
        {
          "name": "POST Crear Campana",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "  const data = pm.response.json();",
                  "  if (data.id) {",
                  "    pm.collectionVariables.set(\"campaignId\", String(data.id));",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Crea una campana y guarda automaticamente el id en la variable campaignId.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Campana Abril\",\n  \"brand\": \"Mi Marca\",\n  \"notes\": \"Prueba de monitoreo\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/campaigns",
              "host": ["{{baseUrl}}"],
              "path": ["campaigns"]
            }
          },
          "response": []
        },
        {
          "name": "GET Listar Campanas",
          "request": {
            "method": "GET",
